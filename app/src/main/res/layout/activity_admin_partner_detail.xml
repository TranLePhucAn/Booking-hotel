<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDetailBusinessName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Người đại diện:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailRepName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Địa chỉ:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mã số thuế:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailTaxCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mô tả:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDetailDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnViewVerificationFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xem file xác minh"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etAdminNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ghi chú của Admin (Lý do từ chối...)"
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRejectApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Từ chối"
                android:backgroundTint="@color/error"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnApproveApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Duyệt"
                android:backgroundTint="@color/ocean_blue"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
