<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/card"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/ocean_blue"/>
        <TextView
            style="@style/TextTitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chi tiết đơn đặt phòng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ocean_deep" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailBookingId"
                        style="@style/TextTitleLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã đơn hàng: #C4mpzNkye0DkXYlgi0ae"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginVertical="8dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trạng thái đơn:"
                            android:textColor="@color/gray_text"/>

                        <TextView
                            android:id="@+id/tvDetailStatus"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="PAID"
                            android:textStyle="bold"
                            android:textColor="@color/ocean_blue"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivDetailRoomImage"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_gradient"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvDetailHotelName"
                            style="@style/TextTitleLarge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="The Passion Lux Airport"
                            android:textSize="18sp"
                            android:textColor="@color/ocean_deep"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvDetailHotelAddress"
                            style="@style/TextSubtitleSmall"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="119 Đường Bạch Đằng, Phường 2, Tân Bình, TP.HCM"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/separate_color"
                            android:layout_marginVertical="10dp"/>

                        <TextView
                            android:id="@+id/tvDetailRoomName"
                            style="@style/TextTitleLarge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Deluxe Double Room"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvDetailRoomSpecs"
                            style="@style/TextInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Diện tích: 32 m²  |   Giường: 1 giường đôi"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/tvDetailRoomCapacity"
                            style="@style/TextInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Sức chứa: 2 người lớn, 1 trẻ em"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/separate_color"
                            android:layout_marginVertical="10dp"/>

                        <TextView
                            android:id="@+id/tvDetailCheckIn"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Nhận phòng: 22 Th06, 2026 (14:00)"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvDetailCheckOut"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Trả phòng: 23 Th06, 2026 (12:00)"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_secondary"/>

                        <TextView
                            android:id="@+id/tvDetailNights"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số đêm lưu trú: 1 đêm"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextTitleLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin liên hệ khách đặt"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginVertical="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailGuestName"
                        style="@style/TextInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khách hàng: Nguyen A"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tvDetailGuestPhone"
                        style="@style/TextInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 Số điện thoại: 0357697206"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tvDetailGuestEmail"
                        style="@style/TextInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️ Email: 23130091@st.hcmuaf.edu.vn"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextTitleLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin chi phí"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginVertical="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            style="@style/TextInfo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Giá phòng "
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tvDetailBasePrice"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.200.000 đ"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            style="@style/TextInfo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thuế và phí dịch vụ khách sạn"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tvDetailTaxFee"
                            style="@style/TextInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120.000 đ"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginVertical="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            style="@style/TextTitleLarge"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tổng tiền thanh toán"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/ocean_deep"/>
                        <TextView
                            android:id="@+id/tvDetailTotalPrice"
                            style="@style/TextTitleLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.320.000 đ"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/highlight_text"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnCancelReservation"
                style="@style/AppButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Hủy đơn đặt phòng"
                android:backgroundTint="@color/warn_text"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnReviewReservation"
                style="@style/AppButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Đánh giá dịch vụ"
                android:backgroundTint="@color/ocean_blue"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>