<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_stayhub" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Khách sạn The Passion Lux Airport" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <RatingBar
                            android:id="@+id/ratingBar"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:rating="2.0"
                            android:stepSize="0.5"
                            android:progressTint="#FFC107"
                            android:layout_marginEnd="4dp"/>

                        <TextView
                            android:id="@+id/textView2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:textStyle="bold"
                            android:textColor="@color/ocean_deep"
                            android:text="8.3/10" />

                        <TextView
                            android:id="@+id/textView3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="@style/TextMore"
                            android:text="(84 đánh giá)" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textView4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Chi tiết phòng đã chọn"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="(1x) Ground Floor Studio With Window - [ Budget Deal ]" />

                    <TextView
                        android:id="@+id/textView6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="@style/TextSubtitleSmall"
                        android:textStyle="bold"
                        android:textColor="@color/warn_text"
                        android:layout_marginBottom="12dp"
                        android:text="Chỉ còn 2 phòng" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/ocean_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/textView7"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfo"
                                android:text="Nhận phòng" />
                            <TextView
                                android:id="@+id/textView8"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfoColor"
                                android:textStyle="bold"
                                android:text="Thứ Tư, 3 thg 6" />
                            <TextView
                                android:id="@+id/textView9"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfo"
                                android:text="Từ 14:00" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/textView10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfo"
                                android:textStyle="bold"
                                android:text="1 đêm" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/textView11"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfo"
                                android:text="Trả phòng" />
                            <TextView
                                android:id="@+id/textView12"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfoColor"
                                android:textStyle="bold"
                                android:text="Thứ Năm, 4 thg 6" />
                            <TextView
                                android:id="@+id/textView13"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/TextInfo"
                                android:text="Trước 12:00" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView14"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextMore"
                            android:text="2 khách" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView15"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextMore"
                            android:text="Đặt phòng này không được hoàn tiền" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textView16"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextMore"
                            android:text="Non-reschedulable" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_price_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Chi tiết giá"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/TextSubtitleSmall"
                            android:text="Giá phòng (1 phòng x 1 đêm)" />

                        <TextView
                            android:id="@+id/tv_base_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:text="1.200.000 đ" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/TextSubtitleSmall"
                            android:text="Thuế &amp; Phí dịch vụ khách sạn" />

                        <TextView
                            android:id="@+id/tv_tax_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:text="120.000 đ" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/et_promo_code"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Nhập mã giảm giá"
                            style="@style/TextMore"
                            android:background="@android:drawable/editbox_background"
                            android:padding="12dp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_apply_promo"
                            style="@style/AppButtonStyle"
                            android:layout_marginStart="8dp"
                            android:text="Áp dụng"
                            android:background="@drawable/bg_button" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_gradient"
                        android:padding="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/TextSubtitleSmall"
                            android:textStyle="bold"
                            android:textColor="@color/card"
                            android:text="Tổng tiền thanh toán" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tv_old_total_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.320.000 đ"
                                android:textColor="#9E9E9E"
                                android:layout_marginEnd="8dp"
                                android:visibility="gone" />

                            <TextView
                            android:id="@+id/tv_total_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                                style="@style/TextSubtitleSmall"
                                android:textStyle="bold"
                            android:textColor="@color/card"
                            android:text="1.320.000 đ" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Điền thông tin cá nhân -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Thông tin liên hệ"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextSubtitleSmall"
                        android:textStyle="bold"
                        android:text="Họ và tên khách hàng *"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_guest_name"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="Nguyễn Văn A"
                        android:inputType="textPersonName"
                        style="@style/TextMore"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_input"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextSubtitleSmall"
                        android:textStyle="bold"
                        android:text="Số điện thoại *"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_guest_phone"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="0901234567"
                        android:inputType="phone"
                        style="@style/TextMore"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_input"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextSubtitleSmall"
                        android:textStyle="bold"
                        android:text="Địa chỉ Email *"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/et_guest_email"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="nguyenvana@email.com"
                        android:inputType="textEmailAddress"
                        style="@style/TextMore"
                        android:paddingHorizontal="12dp"
                        android:background="@drawable/bg_input"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextMore"
                        android:text="* Thông tin này được dùng để gửi vé phòng điện tử và xác nhận trạng thái đặt phòng." />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_confirm_booking"
                style="@style/AppButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="Xác nhận đặt phòng"
                android:background="@drawable/bg_button" />
        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>