<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgHistoryThumbnail"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_gradient"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvHistoryHotelName"
                        style="@style/TextTitleLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Passion Lux Airport"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_toStartOf="@+id/tvHistoryStatus"
                        android:layout_alignParentStart="true"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvHistoryStatus"
                        style="@style/TextInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="ĐÃ THANH TOÁN"
                        android:textStyle="bold"
                        android:textColor="@color/ocean_blue"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvHistoryDate"
                    style="@style/TextSubtitleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 22/06/2026 - 23/06/2026"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvHistoryPrice"
                    style="@style/TextTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.320.000 đ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/highlight_text"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/separate_color"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvBookingId"
                style="@style/TextInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Mã đặt phòng: #C4mpzN"
                android:textColor="@color/gray_text" />

            <Button
                android:id="@+id/btnViewDetail"
                style="@style/AppButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:text="Xem chi tiết"
                android:backgroundTint="@color/ocean_blue"
                app:cornerRadius="8dp"/>
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>