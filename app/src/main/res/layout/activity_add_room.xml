<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvAddRoomTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm phòng"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtRoomName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Ten phòng"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRoomType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Loại phòng, ví dụ Deluxe"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRoomDescription"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Mô tả phòng"
            android:padding="14dp" />

        <EditText
            android:id="@+id/edtRoomPrice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Giá mỗi đêm, ví dụ 650000"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtAdults"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Số người lớn"
            android:inputType="number"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtChildren"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Số trẻ em"
            android:inputType="number"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtBedType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Loại giường"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRoomSize"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Diện tích phòng, ví dụ 32"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtAvailableRooms"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Số lượng phòng còn trống"
            android:inputType="number"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRoomImage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Anh phòng"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRoomAmenities"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Tiện ích phòng, cách nhau bằng dấu phẩy"
            android:paddingHorizontal="14dp" />

        <Button
            android:id="@+id/btnSaveRoom"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/ocean_blue"
            android:text="Lưu phòng"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnFinishHotelPost"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Gửi duyệt bài đăng"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
