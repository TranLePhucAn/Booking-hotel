<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm khách sạn mới"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtBusinessName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Tên doanh nghiệp / chủ khách sạn"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtHotelName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Tên khách sạn"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Mô tả khách sạn"
            android:padding="14dp" />

        <EditText
            android:id="@+id/edtAddress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Địa chỉ khách sạn"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtCity"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Thanh pho"
            android:paddingHorizontal="14dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtDistrict"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Quan / huyen"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtRatingStar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Số sao khách sạn, ví dụ 2"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtPriceFrom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Giá thấp nhất mỗi đêm, ví dụ 500000"
            android:inputType="numberDecimal"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtAmenities"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Tiện ích khách sạn, cách nhau bằng dấu phẩy"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtMainImageUrl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Anh chinh"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtImageUrls"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Danh sách ảnh phụ, cách nhau bằng dấu phẩy"
            android:padding="14dp" />

        <EditText
            android:id="@+id/edtLatitude"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Vĩ độ, ví dụ 10.8131"
            android:inputType="numberDecimal|numberSigned"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtLongitude"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Kinh độ, ví dụ 106.6658"
            android:inputType="numberDecimal|numberSigned"
            android:paddingHorizontal="14dp" />

        <Button
            android:id="@+id/btnSubmitHotel"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/ocean_blue"
            android:text="Tạo khách sạn và thêm phòng"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
