<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivHotelDetail"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"
            android:background="@color/white"/>

        <TextView
            android:id="@+id/tvHotelDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvHotelDetailAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvHotelDetailPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ocean_blue"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mô tả:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvHotelDetailDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiện ích:" android:textStyle="bold"/>
        <TextView android:id="@+id/tvHotelDetailAmenities" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etHotelAdminNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ghi chú của Admin / Lý do từ chối"
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRejectHotel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Từ chối"
                android:backgroundTint="@color/error"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnApproveHotel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Duyệt"
                android:backgroundTint="@color/ocean_blue"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
