<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <TextView
        style="@style/TextTitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lịch sử đặt phòng"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/ocean_deep"
        android:padding="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnFilterUpcoming"
            style="@style/AppButtonStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Sắp đi"
            android:backgroundTint="@color/ocean_blue"/>

        <Button
            android:id="@+id/btnFilterCompleted"
            style="@style/AppButtonStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Đã đi"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/separate_color"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBookingHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>
</LinearLayout>