<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_stayhub" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Khách sạn The Passion Lux Airport" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <RatingBar
                            android:id="@+id/ratingBar"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:rating="2.0"
                            android:stepSize="0.5"
                            android:progressTint="#FFC107"
                            android:layout_marginEnd="4dp"/>

                        <TextView
                            android:id="@+id/textView2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:textStyle="bold"
                            android:textColor="@color/ocean_deep"
                            android:text="8.3/10" />

                        <TextView
                            android:id="@+id/textView3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            style="@style/TextMore"
                            android:text="(84 đánh giá)" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_gradient"
                android:padding="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/TextSubtitleSmall"
                    android:textStyle="bold"
                    android:textColor="@color/card"
                    android:text="Tổng tiền thanh toán" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tv_old_total_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.320.000 đ"
                        android:textColor="#9E9E9E"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_total_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextSubtitleSmall"
                        android:textStyle="bold"
                        android:textColor="@color/card"
                        android:text="1.320.000 đ" />
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextTitleLarge"
                        android:textStyle="bold"
                        android:text="Phương thức thanh toán"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rg_payment_methods"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <RadioButton
                            android:id="@+id/rb_credit_card"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="8dp"
                            android:text="Thẻ tín dụng / Thẻ ghi nợ"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/rb_digital_payment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="8dp"
                            android:text="Thanh toán điện tử (Ví MoMo / QR Ngân hàng)"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/layout_credit_card_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:textStyle="bold"
                            android:text="Tên chủ thẻ *"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/et_card_name"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="NGUYEN VAN A"
                            android:inputType="textCapCharacters"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:textStyle="bold"
                            android:text="Số thẻ *"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/et_card_number"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="0000 0000 0000 0000"
                            android:inputType="number"
                            android:maxLength="16"
                            android:paddingHorizontal="12dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TextSubtitleSmall"
                                    android:textStyle="bold"
                                    android:text="Ngày hết hạn *"
                                    android:layout_marginBottom="6dp" />

                                <EditText
                                    android:id="@+id/et_expiry_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:hint="MM/YY"
                                    android:inputType="text"
                                    android:maxLength="5"
                                    android:paddingHorizontal="12dp"
                                    android:background="@drawable/bg_input" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TextSubtitleSmall"
                                    android:textStyle="bold"
                                    android:text="Mã CVC/CVV *"
                                    android:layout_marginBottom="6dp" />

                                <EditText
                                    android:id="@+id/et_cvv"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:hint="123"
                                    android:inputType="numberPassword"
                                    android:maxLength="3"
                                    android:paddingHorizontal="12dp"
                                    android:background="@drawable/bg_input" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_digital_payment_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/TextSubtitleSmall"
                            android:textColor="@color/ocean_deep"
                            android:text="Hệ thống sẽ tạo mã QR chuyển khoản hoặc cổng ứng dụng MoMo sau khi bạn nhấn nút Đặt phòng." />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/separate_color"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <CheckBox
                android:id="@+id/cb_agree_terms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingVertical="12dp"
                android:paddingHorizontal="8dp"
                style="@style/TextMore"
                android:text="Tôi đã đọc và đồng ý với các Điều khoản &amp; Điều kiện đặt phòng của Stayhub." />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_booking"
                style="@style/AppButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:text="Đặt phòng"
                android:background="@drawable/bg_button" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>