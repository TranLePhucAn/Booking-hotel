<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Chỉnh Sửa Hạng Phòng"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin cơ bản"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_room_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên hạng phòng"
                    android:inputType="text"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại phòng"
                    style="@style/TextMore" />

                <Spinner
                    android:id="@+id/spinner_edit_room_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/room_types_array"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_bed_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Kiểu giường"
                    android:inputType="text"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_room_image_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Đường dẫn ảnh phòng https://..."
                    android:inputType="textUri" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sức chứa &amp; Kho số lượng"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_capacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sức chứa người lớn"
                    android:inputType="number"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_total_rooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tổng số lượng phòng sở hữu"
                    android:inputType="number" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá cả &amp; Tiện ích"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Giá phòng gốc mỗi đêm (VND)"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_edit_base_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Giá bán gói dịch vụ"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="16dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignBounds">

                    <CheckBox
                        android:id="@+id/cb_edit_wifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wifi"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_edit_air"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Máy lạnh"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_edit_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TV"
                        android:layout_columnWeight="1"/>
                </GridLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignBounds">

                    <CheckBox
                        android:id="@+id/cb_is_refundable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cho phép hoàn tiền"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_is_reschedulable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cho phép đổi lịch"
                        android:layout_columnWeight="1"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái kinh doanh"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_hide_room"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Tạm ẩn phòng này (Khách không tìm thấy)"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_disable_room"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Ngừng kinh doanh (Vô hiệu hóa)"
                    android:textColor="#CC0000" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_update_room"
            style="@style/AppButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Lưu thay đổi"
            android:textSize="14sp"
            android:background="@drawable/bg_button" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>