<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Thêm Hạng Phòng Mới"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin cơ bản"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_room_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên hạng phòng (Ví dụ: Standard Room)"
                    android:inputType="text"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại phòng"
                    style="@style/TextMore" />

                <Spinner
                    android:id="@+id/spinner_room_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/room_types_array"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_bed_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Kiểu giường (Ví dụ: 1 giường đôi)"
                    android:inputType="text" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sức chứa &amp; Số lượng phòng"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_capacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sức chứa người lớn"
                    android:inputType="number"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_total_rooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tổng số lượng phòng sở hữu"
                    android:inputType="number" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="*Lưu ý: Số phòng có sẵn ban đầu sẽ tự động gán bằng tổng số phòng."
                    style="@style/TextMore" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá phòng &amp; Mô tả"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Giá phòng mỗi đêm (VND)"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mô tả chi tiết phòng..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiện ích phòng (Amenities)"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignBounds">

                    <CheckBox
                        android:id="@+id/cb_wifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wifi"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_air_conditioner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Máy lạnh"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TV"
                        android:layout_columnWeight="1"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cấu hình Gói hiển thị &amp; Chính sách"
                    style="@style/TextHighLightLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_room_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên hiển thị gói (Ví dụ: Studio kèm Cửa sổ)"
                    android:inputType="text"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_base_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Giá trọn gói (Ví dụ: 1200000)"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignBounds">

                    <CheckBox
                        android:id="@+id/cb_is_refundable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cho phép hoàn tiền"
                        android:layout_columnWeight="1"/>

                    <CheckBox
                        android:id="@+id/cb_is_reschedulable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cho phép đổi lịch"
                        android:layout_columnWeight="1"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_save_room"
            style="@style/AppButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Tạo hạng phòng mới"
            android:textSize="14sp"
            android:background="@drawable/bg_button" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>